{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arqitech/dgx-spark-bench/schema/results.schema.json",
  "title": "DGX Spark Benchmark Results",
  "description": "One benchmark run: a concurrency sweep of one or more (model, quant, backend) configurations on one machine. Emitted by the harness, consumed by web/index.html. This file is the contract between the two.",
  "type": "object",
  "required": ["schema_version", "run", "series"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run": {
      "type": "object",
      "required": ["id", "timestamp", "harness_version", "hardware", "workload"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Unique run id, e.g. 2026-06-25T14-03Z-spark01." },
        "timestamp": { "type": "string", "format": "date-time" },
        "harness_version": { "type": "string" },
        "git_commit": { "type": "string", "description": "Commit of the harness used, for reproducibility." },
        "hardware": {
          "type": "object",
          "required": ["name", "mem_gb", "bw_gbs"],
          "properties": {
            "name": { "type": "string", "examples": ["DGX Spark"] },
            "soc": { "type": "string", "examples": ["GB10 Grace Blackwell"] },
            "mem_gb": { "type": "number" },
            "mem_type": { "type": "string", "examples": ["LPDDR5x"] },
            "bw_gbs": { "type": "number", "description": "Memory bandwidth in GB/s." },
            "fp4_tops": { "type": "number" },
            "driver": { "type": "string" },
            "cuda": { "type": "string" },
            "gpu_index": { "type": "integer", "description": "GPU index from nvidia-smi." },
            "temperature_c": { "type": ["integer", "null"], "description": "GPU temperature in °C from nvidia-smi (None if unavailable)." },
            "power_draw_w": { "type": ["number", "null"], "description": "GPU power draw in watts from nvidia-smi (None if unavailable)." },
            "power_limit_w": { "type": ["integer", "null"], "description": "GPU power limit in watts from nvidia-smi (None if unavailable)." }
          }
        },
        "workload": {
          "type": "object",
          "required": ["prompt_tokens", "output_tokens", "mode"],
          "properties": {
            "name": { "type": "string", "examples": ["chat", "rag", "summarize"] },
            "prompt_tokens": { "type": "integer", "description": "Fixed input length per request." },
            "output_tokens": { "type": "integer", "description": "Capped output length per request (max_tokens)." },
            "mode": { "type": "string", "enum": ["closed_loop", "open_loop"] },
            "arrival_rate_rps": { "type": "number", "description": "Only for open_loop." }
          }
        },
        "sweep": {
          "type": "object",
          "description": "Sweep timing used for this run, so windows are comparable across results.",
          "properties": {
            "concurrencies": { "type": "array", "items": { "type": "integer" } },
            "warmup_s": { "type": "number" },
            "measure_s": { "type": "number" },
            "request_timeout_s": { "type": "number" }
          }
        }
      }
    },
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "model", "quant", "backend", "status", "points"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "model": { "type": "string" },
          "params_b": { "type": "number", "description": "Parameter count in billions." },
          "quant": { "type": "string", "examples": ["NVFP4", "FP8", "GGUF Q4_K_M", "MXFP4", "BF16"] },
          "backend": { "type": "string", "examples": ["vLLM", "TensorRT-LLM", "SGLang", "llama.cpp", "Ollama"] },
          "backend_version": { "type": "string" },
          "status": { "type": "string", "enum": ["measured", "projected"], "description": "measured = real run; projected = modeled from an anchor. Rendered solid vs dashed." },
          "weights_gb": { "type": "number" },
          "max_concurrency": { "type": "integer", "description": "KV-cache capacity ceiling at this workload — curve terminates here." },
          "source": { "type": "string", "description": "Provenance for measured/projected, e.g. 'LMSYS 2025-10-13' or 'this run'." },
          "color": { "type": "string", "description": "Optional hex; UI assigns from palette if absent." },
          "config": {
            "type": "object",
            "description": "Serving config the series was measured with — the load-bearing engine knobs, curated (not an exhaustive flag dump). Keys free-form, values scalar.",
            "additionalProperties": { "type": ["string", "number", "boolean"] }
          },
          "recipe_url": { "type": "string", "format": "uri", "description": "Link to the reproducible recipe (bench-profile yaml + harness config) for this series." },
          "points": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["concurrency", "agg_tok_s", "per_session_tok_s", "ttft_ms"],
              "additionalProperties": false,
              "properties": {
                "concurrency": { "type": "integer", "description": "Number of parallel sessions (closed-loop) at this point." },
                "agg_tok_s": { "type": "number", "description": "Aggregate output (decode) tokens/sec across all sessions." },
                "per_session_tok_s": { "type": "number" },
                "ttft_ms": {
                  "type": "object",
                  "required": ["p50", "p95", "p99"],
                  "properties": {
                    "p50": { "type": "number" }, "p95": { "type": "number" }, "p99": { "type": "number" }
                  }
                },
                "itl_ms": {
                  "type": "object",
                  "description": "Inter-token latency percentiles.",
                  "properties": { "p50": { "type": "number" }, "p95": { "type": "number" }, "p99": { "type": "number" } }
                },
                "anchor": { "type": "boolean", "description": "True if this exact point is backed by a real measurement (vs interpolated/projected)." },
                "samples": { "type": "integer", "description": "Number of completed requests aggregated into this point." },
                "_failures": { "type": "integer", "description": "Requests that errored at this point (diagnostic; healthy runs omit it)." },
                "gpu": {
                  "type": "object",
                  "description": "GPU thermal/power snapshot captured after this concurrency point.",
                  "properties": {
                    "temperature_c": { "type": ["integer", "null"], "description": "GPU temperature in °C (None if nvidia-smi unavailable)." },
                    "power_draw_w": { "type": ["number", "null"], "description": "GPU power draw in watts (None if nvidia-smi unavailable)." }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
